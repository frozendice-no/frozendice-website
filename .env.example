# --- Sanity (auto-injected by Vercel Native Sanity integration) ---
# Run `vercel env pull .env.local` to populate in local dev.
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_READ_TOKEN=""
SANITY_API_WRITE_TOKEN=""

# --- Sanity webhook (manually generated) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SANITY_WEBHOOK_SECRET=""

# --- Database (Neon Postgres) — required until Phase 6 cleanup ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Stripe — required for digital store checkout ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend — transactional email (order confirmations, download links) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Frozen Dice <hello@send.frozendice.no>

# --- Google Tag Manager — optional, enables analytics ---
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- YouTube Data API v3 (added in Phase 4) ---
# Used for the LIVE pill: GET /api/youtube/live-status polls search.list?eventType=live.
# Create a key at https://console.developers.google.com/ with YouTube Data API v3 enabled.
# Channel ID is the UCxxxxxxxx... string from YouTube Studio (Settings → Channel → Basic info).
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""
# Public version of YOUTUBE_CHANNEL_ID — used in the "Watch Live" CTA href on the landing hero.
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=""

# --- Vercel Blob (added in Phase 3) ---
# BLOB_READ_WRITE_TOKEN=""
