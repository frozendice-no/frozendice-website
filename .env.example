# Database (Neon Postgres) — required
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Stripe — required for digital store checkout
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — optional, enables welcome emails on newsletter signup
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Frozen Dice <hello@send.frozendice.no>

# Google Tag Manager — optional, enables analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
